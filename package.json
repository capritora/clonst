{
  "name": "@clonst/clonst",
  "version": "1.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "MCP server that lets Claude Code get its plans and code adversarially reviewed by Codex, in a ping-pong loop until consensus",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clonst": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/tests"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm test && npm run smoke && node scripts/check-npm-pack.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "smoke": "node scripts/smoke-mcp.mjs",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\""
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "codex",
    "openai",
    "anthropic",
    "chatgpt",
    "code-review",
    "ai-code-review",
    "adversarial-review",
    "second-opinion",
    "llm",
    "developer-tools"
  ],
  "author": "Christopher <christopher@capritora.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/capritora/clonst.git"
  },
  "homepage": "https://github.com/capritora/clonst#readme",
  "bugs": {
    "url": "https://github.com/capritora/clonst/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
